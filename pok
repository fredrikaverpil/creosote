#!/bin/bash
set -e

# Resolve shim directory to find .pocket
SHIM_DIR="$(cd "$(dirname "$0")" && pwd)"

POCKET_DIR="$SHIM_DIR/.pocket"
TASK_SCOPE="."
GO_VERSION="1.26.1"
GO_INSTALL_DIR="$POCKET_DIR/tools/go/$GO_VERSION"
GO_BIN="$GO_INSTALL_DIR/go/bin/go"

# Find Go binary
if command -v go &> /dev/null; then
    GO_CMD="go"
elif [[ -x "$GO_BIN" ]]; then
    GO_CMD="$GO_BIN"
else
    # Download Go
    echo "Go not found, downloading go$GO_VERSION..."
    OS=$(uname -s | tr '[:upper:]' '[:lower:]')
    ARCH=$(uname -m)
    [[ "$ARCH" == "x86_64" ]] && ARCH="amd64"
    [[ "$ARCH" == "aarch64" || "$ARCH" == "arm64" ]] && ARCH="arm64"

    # Get expected checksum for this platform
    EXPECTED_SHA256=""
    case "${OS}-${ARCH}" in
        "aix-ppc64") EXPECTED_SHA256="75441456c5fb8338b2691d22d7e91cc756f79defaa4268d6e04ab85ca1a1f4a3" ;;
        "darwin-amd64") EXPECTED_SHA256="65773dab2f8cc4cd23d93ba6d0a805de150ca0b78378879292be0b903b8cdd08" ;;
        "darwin-arm64") EXPECTED_SHA256="353df43a7811ce284c8938b5f3c7df40b7bfb6f56cb165b150bc40b5e2dd541f" ;;
        "dragonfly-amd64") EXPECTED_SHA256="f415e65bfcb03989a4b6eddedcd582cd509ea619af588b1341416216642c78fb" ;;
        "freebsd-386") EXPECTED_SHA256="afb86dcd5240cf93627171a169973c75d9d139a69ed8e0be120d49b24943c13f" ;;
        "freebsd-amd64") EXPECTED_SHA256="d89034a0b54fdc234815fecfb76d7d06a7d180d7a6124aa47715a4cacc9fe999" ;;
        "freebsd-arm") EXPECTED_SHA256="c60b5b09a24680e40a906df62af71563af4cca0106f01390f2a2346bbfbc4aaa" ;;
        "freebsd-arm64") EXPECTED_SHA256="d62b358dbf7bcfc33402e7e221d848e7fd8d7ac902b33920f2c23c8a32ba76db" ;;
        "illumos-amd64") EXPECTED_SHA256="78e9a3d99fab9626b773a859f28f69ca5240846487f51b92b51251ef04f210bc" ;;
        "linux-386") EXPECTED_SHA256="da75d696c6b9440fe9fb6418429f29eaeee947707ee8c6ddb567c558051a1cc2" ;;
        "linux-amd64") EXPECTED_SHA256="031f088e5d955bab8657ede27ad4e3bc5b7c1ba281f05f245bcc304f327c987a" ;;
        "linux-arm64") EXPECTED_SHA256="a290581cfe4fe28ddd737dde3095f3dbeb7f2e4065cab4eae44dfc53b760c2f7" ;;
        "linux-armv6l") EXPECTED_SHA256="c9937198994dc173b87630a94a0d323442bef81bf7589b1170d55a8ebf759bda" ;;
        "linux-loong64") EXPECTED_SHA256="922b0f308771ce7e162f6c14a9d4bc86db329eaacf6db875e967ad7e5a6b065c" ;;
        "linux-mips") EXPECTED_SHA256="8711f0396539d9051f27b7743c69ab48359dea75cfaa37b8c70b6ddf6b5d8259" ;;
        "linux-mips64") EXPECTED_SHA256="bbe2604bdf51e08d6386da7632f07379f88f31b2431ae71839a7064201a8ffd3" ;;
        "linux-mips64le") EXPECTED_SHA256="1d97c7293a9760afb4a6e02d19e627d7eecea75b4f06096fd39b7977e4830b96" ;;
        "linux-mipsle") EXPECTED_SHA256="2051d0dc77d8e35aaab39236ae1f913098bbee493c7ed6a6281a8dd5dc1e5db7" ;;
        "linux-ppc64") EXPECTED_SHA256="a14f56b7483c3829e7eb92766956b0b7c3cbb21d055d31c3d327a15baf5535c6" ;;
        "linux-ppc64le") EXPECTED_SHA256="f56eed002998f5f51fa07fd4ed0c5de5e02d51cec7a4007f771c7576620d9d45" ;;
        "linux-riscv64") EXPECTED_SHA256="56f8a63ae986c75e91001d65e17648564a10f0d2b18d696d13c91e459da1abd4" ;;
        "linux-s390x") EXPECTED_SHA256="60fe623ef63e6338c055ec0e0e3f4fa85c97a056de2d2f6ee38591e2bfa9cdde" ;;
        "netbsd-386") EXPECTED_SHA256="158b816ce02a2a8cb07aca558bd332ba3b6f56d3b873f48979231f8beaa458a1" ;;
        "netbsd-amd64") EXPECTED_SHA256="42bf3dba3d2c023fb7cce66806e300d389951b2ba50484eb6a2d8cdb8baa8b50" ;;
        "netbsd-arm") EXPECTED_SHA256="7107542cc768b1bdf713e33e7034dd2a5ca98e7357643c2c9695c6be5176a590" ;;
        "netbsd-arm64") EXPECTED_SHA256="498845f0c6b5eb3136c1a21b87940e55a039639f0757b91016172e67ce899032" ;;
        "openbsd-386") EXPECTED_SHA256="aba9d96b620eac5a3b47c0e58dc2a2d773c365991a6e1a9b681b8c77542adbed" ;;
        "openbsd-amd64") EXPECTED_SHA256="8801baa1cc9d221b863b005555ba3c6cbd27fb50b651f7e31ea129d0ada27577" ;;
        "openbsd-arm") EXPECTED_SHA256="cdeb25b4d496c3e6610d86292af8c2699bca40cfdad27dd6366ea032e29f233b" ;;
        "openbsd-arm64") EXPECTED_SHA256="398f0074552368b0f8d874712a69bb4c999d16edaceaa31ff7dde735f524e815" ;;
        "openbsd-ppc64") EXPECTED_SHA256="74e95fa65c22cd2ab09a69532517bac51da5a66827766abd721f20a4fd9120dc" ;;
        "openbsd-riscv64") EXPECTED_SHA256="1a78ed5f05959bda1a7feee108bb96fd46ca50f8f8ff60484fef0b6436bf36c0" ;;
        "plan9-386") EXPECTED_SHA256="214a665bbf5204caa1111a15a9607b3f0057ea9721e0dafbd5a71303de0708c4" ;;
        "plan9-amd64") EXPECTED_SHA256="c6b0bd3c0f0f4c62191c665a27df9f79470572ad29ecf6064368f3bde43c14bc" ;;
        "plan9-arm") EXPECTED_SHA256="9caf03c5455fe14dd622cba54edc4655a895e302f09e34a6dd19c4ebc7c53786" ;;
        "solaris-amd64") EXPECTED_SHA256="e9d67570e05e43120692be78bf7497a22ff413526f8d6b7378bba9607a151b5b" ;;
        "windows-386") EXPECTED_SHA256="6a26b7ce038d96d2b3457ea4933667fb85c896411860216daf6ea17ecd4b25c5" ;;
        "windows-amd64") EXPECTED_SHA256="9b68112c913f45b7aebbf13c036721264bbba7e03a642f8f7490c561eebd1ecc" ;;
        "windows-arm64") EXPECTED_SHA256="c17e09676be0faad3cbed1c81bb02f38fb73e2f93d048571cc13730fe23f2d5b" ;;
    esac

    DOWNLOAD_URL="https://go.dev/dl/go${GO_VERSION}.${OS}-${ARCH}.tar.gz"
    DOWNLOAD_FILE=$(mktemp)
    trap 'rm -f "$DOWNLOAD_FILE"' EXIT

    curl -fsSL "$DOWNLOAD_URL" -o "$DOWNLOAD_FILE"

    # Verify checksum if we have an expected value and a tool to compute it
    if [[ -n "$EXPECTED_SHA256" ]]; then
        ACTUAL_SHA256=""
        if command -v sha256sum &> /dev/null; then
            ACTUAL_SHA256=$(sha256sum "$DOWNLOAD_FILE" | cut -d' ' -f1)
        elif command -v shasum &> /dev/null; then
            ACTUAL_SHA256=$(shasum -a 256 "$DOWNLOAD_FILE" | cut -d' ' -f1)
        elif command -v openssl &> /dev/null; then
            ACTUAL_SHA256=$(openssl dgst -sha256 "$DOWNLOAD_FILE" | awk '{print $NF}')
        fi

        if [[ -n "$ACTUAL_SHA256" ]]; then
            if [[ "$ACTUAL_SHA256" != "$EXPECTED_SHA256" ]]; then
                echo "Checksum verification failed!" >&2
                echo "Expected: $EXPECTED_SHA256" >&2
                echo "Actual:   $ACTUAL_SHA256" >&2
                exit 1
            fi
            echo "Checksum verified."
        else
            echo "Warning: No checksum tool available (sha256sum, shasum, or openssl), skipping verification."
        fi
    else
        echo "Warning: No checksum available for ${OS}-${ARCH}, skipping verification."
    fi

    mkdir -p "$GO_INSTALL_DIR"
    tar -xzf "$DOWNLOAD_FILE" -C "$GO_INSTALL_DIR"
    GO_CMD="$GO_BIN"
    echo "Go $GO_VERSION installed to $GO_INSTALL_DIR"
fi

TASK_SCOPE="$TASK_SCOPE" "$GO_CMD" run -C "$POCKET_DIR" . "$@"
